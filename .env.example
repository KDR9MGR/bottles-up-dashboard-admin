# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env (git-ignored) and fill in the values below.
# Find both values in: Supabase Dashboard → Project Settings → API

# Your project's REST/Auth endpoint
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — safe to expose in the browser.
# Row-Level Security policies on the database enforce actual access control.
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ─── Vercel (set in Vercel Dashboard, NOT in this file) ─────────────────────
# These are used by the Supabase edge function, not the frontend.
# Add them under: Vercel Project → Settings → Environment Variables
#   (or via: vercel env add <NAME>)
#
# STRIPE_SECRET_KEY=sk_live_...   ← server-side only, never in the browser
